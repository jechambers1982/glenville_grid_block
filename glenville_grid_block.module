<?php

/**
 * Implements hook_theme().
 */
function glenville_grid_block_theme($existing, $type, $theme, $path) {
  // Get the module's path via the extension manager service.
  $module_path = \Drupal::service('extension.list.module')->getPath('glenville_grid_block');
  $templates_path = $module_path . '/templates/paragraphs';

  return [
    // Parent bundle: glen_grid_block.
    'paragraph__glen_grid_block' => [
      'base hook' => 'paragraph',
      'template'  => 'paragraph--glen-grid-block',
      'path'      => $templates_path,
    ],
    // Child bundle: glen_grid_block_item.
    'paragraph__glen_grid_block_item' => [
      'base hook' => 'paragraph',
      'template'  => 'paragraph--glen-grid-block-item',
      'path'      => $templates_path,
    ],
  ];
}

function glenville_grid_block_preprocess_paragraph(array &$vars) {
  $bundle = $vars['paragraph']->bundle();
  if (in_array($bundle, ['glen_grid_block', 'glen_grid_block_item'], true)) {
    $vars['#attached']['library'][] = 'glenville_grid_block/grid';
  }
}
